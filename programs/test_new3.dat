%%
addi X1, X0, 100
addi X2, X0, 5
addi X3, X0, 0
addi X4, X0, 4
fld F1, 0(X1)
fadd F2, F1, F1
fadd F3, F1, F1
fmul F3, F3, F1
fadd F4, F1, F1
loop: fadd F4, F4, F1
fmul F3, F3, F1
fsd F4, 0(X1)
addi X1, X1, X4
addi X3, X3, 1
slt X5, X3, X2
bne X5, X0, loop
fadd F2, F2, F4
fmul F3, F3, F1
fsd F2, 200(X0)
fsd F3, 204(X0)
