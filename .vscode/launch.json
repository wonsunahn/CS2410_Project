{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug sim",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/sim",
            "args": ["-d", "-c", "${workspaceFolder}/configs/2-wide.cfg", "-p", "${workspaceFolder}/programs/prog-noloop.dat", "-j", "${workspaceFolder}/outputs/prog-noloop.2-wide.json"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}